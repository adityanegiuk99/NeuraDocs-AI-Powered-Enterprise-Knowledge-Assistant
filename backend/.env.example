# === App ===
APP_NAME=knowledge-assistant
APP_ENV=development
DEBUG=true

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./data/knowledge_assistant.db

# === Auth ===
JWT_SECRET_KEY=change-me-to-a-secure-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === Embeddings ===
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_PROVIDER=huggingface

# === LLM ===
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-your-key-here
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.1

# === Retrieval ===
FAISS_INDEX_PATH=data/faiss_index/index.faiss
TOP_K_RETRIEVAL=50
TOP_K_RERANK=5
SIMILARITY_THRESHOLD=0.35
